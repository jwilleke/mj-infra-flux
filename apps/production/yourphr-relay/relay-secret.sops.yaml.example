# TEMPLATE ONLY — do not commit a real secret in plaintext.
#
# The relay needs a shared secret (YOURPHR_RELAY_SECRET) that gates /pending; the
# same value must be configured on the YourPHR instance that polls the relay.
#
# To produce the encrypted, Flux-decryptable secret:
#
#   1. Copy this file and set a strong random value:
#        cp relay-secret.sops.yaml.example /tmp/relay-secret.yaml
#        # edit /tmp/relay-secret.yaml: YOURPHR_RELAY_SECRET: "$(openssl rand -base64 32)"
#   2. Encrypt in place to the repo's age recipient (creation rules in the repo):
#        sops --encrypt /tmp/relay-secret.yaml > apps/production/yourphr-relay/relay-secret.sops.yaml
#   3. Add `- ./relay-secret.sops.yaml` to kustomization.yaml (uncomment the line there).
#
# Flux's apps Kustomization decrypts *.sops.yaml automatically (same as the other
# *.sops.yaml secrets in this repo). NEVER commit the plaintext /tmp file.
apiVersion: v1
kind: Secret
metadata:
  name: yourphr-relay
  namespace: yourphr
type: Opaque
stringData:
  YOURPHR_RELAY_SECRET: "REPLACE_ME"
