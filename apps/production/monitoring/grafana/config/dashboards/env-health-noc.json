        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "min(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "instant": true,
          "legendFormat": "node",
          "refId": "A"
        }
      ]
    },
