{
  "annotations": { "list": [] },
  "description": "Errors and warnings shipped from the deby host journal by fluent-bit, queried from Loki. Severe events also fire alerts via the existing Alertmanager → Gmail → jim@willeke.com path.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "tags": ["deby", "loki", "logs"],
  "title": "deby — host errors",
  "uid": "deby-host-errors",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "Loki" },
        "hide": 0,
        "regex": ""
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Errors (selected range)",
      "id": 1,
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "refId": "A",
          "expr": "sum(count_over_time({host=\"deby\", log_level=\"error\"}[$__range]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Warnings (selected range)",
      "id": 2,
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "refId": "A",
          "expr": "sum(count_over_time({host=\"deby\", log_level=\"warning\"}[$__range]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Distinct units emitting errors",
      "id": 3,
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "refId": "A",
          "expr": "count(count by (unit) (count_over_time({host=\"deby\", log_level=\"error\", unit=~\".+\"}[$__range])))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Loki ingest rate (lines/s)",
      "id": 4,
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "decimals": 1 }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "refId": "A",
          "expr": "sum(rate({host=\"deby\"}[5m]))"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Errors / min, by unit (top 10)",
      "id": 10,
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 70,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "refId": "A",
          "expr": "topk(10, sum by (unit) (count_over_time({host=\"deby\", log_level=\"error\", unit=~\".+\"}[1m])))",
          "legendFormat": "{{unit}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Warnings / min, by unit (top 10)",
      "id": 11,
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 70,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "refId": "A",
          "expr": "topk(10, sum by (unit) (count_over_time({host=\"deby\", log_level=\"warning\", unit=~\".+\"}[1m])))",
          "legendFormat": "{{unit}}"
        }
      ]
    },

    {
      "type": "logs",
      "title": "Recent errors",
      "id": 20,
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 22 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "refId": "A",
          "expr": "{host=\"deby\", log_level=\"error\"} | json | line_format \"{{ if .unit }}[{{.unit}}] {{ end }}{{ .MESSAGE }}\""
        }
      ]
    }
  ]
}
